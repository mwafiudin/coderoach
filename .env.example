# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Postgres connection string. Accepts any of:
#   DATABASE_URI (Payload convention)
#   POSTGRES_URL (Vercel/Supabase convention)
#   DATABASE_URL (Prisma/Neon convention)
# Pull from Vercel after Postgres provisioned: `vercel env pull .env.local`
DATABASE_URI=postgresql://user:password@host/db?sslmode=require

# Vercel Blob (set automatically when integrated via Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# Public site URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Branding (also editable in admin → Site Settings — these are first-boot fallbacks)
NEXT_PUBLIC_SITE_NAME=Studio

# Email — Resend (https://resend.com)
# Free tier: 100/day. Used for contact form notifications + admin emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@example.com
RESEND_TO_EMAIL=hello@example.com
